FOLDMIND_API_TITLE=FoldMind AI Core
FOLDMIND_API_VERSION=0.1.0
FOLDMIND_CORS_ORIGINS=http://localhost:3000
FOLDMIND_CORS_ALLOW_CREDENTIALS=true

AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2
LLM_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_VERSION=text-embedding-3-small
CHUNKING_VERSION=chunking-v1
INDEX_SCHEMA_VERSION=index-schema-v1
PROFILE_VERSION=profile-v1
PROFILE_SCHEMA_VERSION=profile-schema-v1
DOCUMENT_PROFILE_PROMPT_VERSION=document-profile-prompt-v1
EMBEDDING_DIMENSIONS=1536
PROMPT_ROOT=

FOLDMIND_WORKFLOW_CHECKPOINT_DSN=
FOLDMIND_ALLOW_IN_MEMORY_WORKFLOW_CHECKPOINT=false

POSTGRES_DSN=postgresql://foldmind:foldmind@postgres:5432/foldmind_ai_core

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_DOCUMENT_CHUNK_COLLECTION=document_chunks
QDRANT_DOCUMENT_COLLECTION=documents
QDRANT_FOLDER_COLLECTION=folders
QDRANT_VECTOR_SIZE=1536
QDRANT_DISTANCE=Cosine

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=foldmind
NEO4J_DATABASE=neo4j

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_OUTBOX_TOPIC=outbox_events
OUTBOX_PROJECTION_TARGET=neo4j-graph
KAFKA_DLQ_TOPIC=outbox_events.dlq
KAFKA_MAX_RETRIES=3
KAFKA_RETRY_BACKOFF_SECONDS=1
