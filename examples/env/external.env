POSTGRES_DSN=postgresql://foldmind_ai_core:REPLACE_ME@db.example.com:5432/foldmind_ai_core?sslmode=require

AI_PROVIDER=openai
OPENAI_API_KEY=REPLACE_ME
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2
LLM_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_VERSION=text-embedding-3-small
CHUNKING_VERSION=chunking-v1
INDEX_SCHEMA_VERSION=index-schema-v1
PROFILE_VERSION=profile-v1
PROFILE_SCHEMA_VERSION=profile-schema-v1
DOCUMENT_PROFILE_PROMPT_VERSION=document-profile-prompt-v1
EMBEDDING_DIMENSIONS=1536

QDRANT_URL=https://REPLACE_ME.cloud.qdrant.io
QDRANT_API_KEY=REPLACE_ME
QDRANT_DOCUMENT_CHUNK_COLLECTION=document_chunks
QDRANT_DOCUMENT_COLLECTION=documents
QDRANT_FOLDER_COLLECTION=folders
QDRANT_VECTOR_SIZE=1536
QDRANT_DISTANCE=Cosine

NEO4J_URI=neo4j+s://REPLACE_ME.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=REPLACE_ME
NEO4J_DATABASE=neo4j

KAFKA_BOOTSTRAP_SERVERS=REPLACE_ME:9092
KAFKA_OUTBOX_TOPIC=indexing-events
OUTBOX_PROJECTION_TARGET=neo4j-graph
KAFKA_DLQ_TOPIC=indexing-events.dlq
KAFKA_MAX_RETRIES=3
KAFKA_RETRY_BACKOFF_SECONDS=1
