FOLDMIND_POSTGRES_DSN=postgresql://foldmind:foldmind@postgres:5432/foldmind_ai_core

FOLDMIND_AI_PROVIDER=openai
FOLDMIND_OPENAI_API_KEY=REPLACE_ME
FOLDMIND_OPENAI_BASE_URL=
FOLDMIND_OPENAI_TIMEOUT_SECONDS=60
FOLDMIND_OPENAI_MAX_RETRIES=2
FOLDMIND_LLM_MODEL=gpt-4.1-mini
FOLDMIND_EMBEDDING_MODEL=text-embedding-3-small
FOLDMIND_EMBEDDING_VERSION=text-embedding-3-small
FOLDMIND_CHUNKING_VERSION=chunking-v1
FOLDMIND_INDEX_SCHEMA_VERSION=index-schema-v1
FOLDMIND_DOCUMENT_PROFILE_PROMPT_VERSION=document-profile-prompt-v1
FOLDMIND_EMBEDDING_DIMENSIONS=1536

FOLDMIND_QDRANT_URL=http://qdrant:6333
FOLDMIND_QDRANT_API_KEY=
FOLDMIND_QDRANT_DOCUMENT_CHUNK_COLLECTION=document_chunks
FOLDMIND_QDRANT_DOCUMENT_COLLECTION=documents
FOLDMIND_QDRANT_FOLDER_COLLECTION=folders
FOLDMIND_QDRANT_VECTOR_SIZE=1536
FOLDMIND_QDRANT_DISTANCE=Cosine

FOLDMIND_NEO4J_URI=bolt://neo4j:7687
FOLDMIND_NEO4J_USER=neo4j
FOLDMIND_NEO4J_PASSWORD=foldmind
FOLDMIND_NEO4J_DATABASE=neo4j

FOLDMIND_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
FOLDMIND_KAFKA_OUTBOX_TOPIC=indexing-events
FOLDMIND_OUTBOX_PROJECTION_TARGET=neo4j-graph
FOLDMIND_KAFKA_DEAD_LETTER_TOPIC=indexing-events.dlq
FOLDMIND_KAFKA_MAX_RETRIES=3
FOLDMIND_KAFKA_RETRY_BACKOFF_SECONDS=1
